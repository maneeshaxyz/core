#!/usr/bin/env bash
#
# commit-msg hook — enforce Conventional Commits format
# https://www.conventionalcommits.org/
#
# Bypass: git commit --no-verify

MSG_FILE="$1"
read -r FIRST_LINE < "$MSG_FILE"

# Skip generated commit messages (merge, revert, fixup, squash).
case "$FIRST_LINE" in
  Merge\ *|Revert\ *|fixup\!\ *|squash\!\ *) exit 0 ;;
esac

# type(scope)!: description  —  scope and ! are optional.
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9/_.-]+\))?!?: .+'

if [[ ! "$FIRST_LINE" =~ $PATTERN ]]; then
  if [ -t 2 ]; then
    RED=$'\033[31m'; BLD=$'\033[1m'; RST=$'\033[0m'
  else RED=""; BLD=""; RST=""; fi
  printf '%sFAIL%s commit message does not follow Conventional Commits.\n' "$RED" "$RST" >&2
  printf '     got:      %s\n' "$FIRST_LINE" >&2
  printf '\n' >&2
  printf '     format:   %s<type>%s(<scope>): <description>\n' "$BLD" "$RST" >&2
  printf '     types:    feat  fix  docs  refactor  test  build  ci  chore  revert\n' >&2
  printf '     examples: feat(payment): add retry logic\n' >&2
  printf '               fix: handle nil pointer in auth middleware\n' >&2
  printf '               feat!: rename Config struct  (breaking change)\n' >&2
  printf '\n' >&2
  printf '     bypass:   git commit --no-verify\n' >&2
  exit 1
fi
